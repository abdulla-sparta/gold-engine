# Upstox credentials (from Upstox developer console — create a NEW app for GoldEngine)
UPSTOX_API_KEY=your_key_here
UPSTOX_API_SECRET=your_secret_here
UPSTOX_REDIRECT_URI=https://your-goldengine.up.railway.app/callback

# Twelve Data (free tier — sign up at twelvedata.com)
TWELVE_DATA_API_KEY=your_twelve_data_key

# Telegram (same bot as StructureEngine or create a new one)
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Flask
SECRET_KEY=your_random_secret_key

# PostgreSQL (auto-set by Railway PostgreSQL plugin)
# DATABASE_URL=postgresql://...

# Optional
STARTING_BALANCE=200000
